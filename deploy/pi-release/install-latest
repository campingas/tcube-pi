#!/usr/bin/env bash
set -euo pipefail

repo="${TCUBE_PI_REPO:-campingas/tcube-pi}"
version="${TCUBE_PI_VERSION:-}"

if [[ "${EUID}" -ne 0 ]]; then
  echo "Run with sudo: curl -fsSL https://raw.githubusercontent.com/${repo}/main/deploy/pi-release/install-latest | sudo bash" >&2
  exit 1
fi

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

need_cmd curl
need_cmd grep
need_cmd sed
need_cmd sha256sum
need_cmd tar

if [[ -z "${version}" ]]; then
  version="$(
    curl -fsSL "https://api.github.com/repos/${repo}/releases/latest" \
      | sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p' \
      | head -n 1
  )"
fi

if [[ ! "${version}" =~ ^v[0-9]+\.[0-9]+\.[0-9]+([-+][0-9A-Za-z.-]+)?$ ]]; then
  echo "Invalid or unresolved release version: ${version}" >&2
  exit 1
fi

archive_name="tcube-pi-${version}-linux-arm64.tar.gz"
release_base="https://github.com/${repo}/releases/download/${version}"
work_dir="$(mktemp -d)"

cleanup() {
  rm -rf "${work_dir}"
}
trap cleanup EXIT

cd "${work_dir}"

echo "Downloading T-Cube Pi ${version} release bundle..."
curl -fL --retry 3 -O "${release_base}/${archive_name}"
curl -fL --retry 3 -O "${release_base}/SHA256SUMS"

echo "Verifying release archive..."
grep " ${archive_name}$" SHA256SUMS | sha256sum -c -

tar -xzf "${archive_name}"
cd "tcube-pi-${version}-linux-arm64"

echo "Verifying installer and binaries..."
grep -E ' (bin/|install\.sh$)' ../SHA256SUMS | sha256sum -c -

echo "Installing T-Cube Pi ${version}..."
./install.sh
