#!/usr/bin/env bash
set -euo pipefail

if [[ "${EUID}" -ne 0 ]]; then
  echo "Run this installer with sudo: sudo ./install.sh" >&2
  exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

require_path() {
  local path="$1"
  if [[ ! -e "${path}" ]]; then
    echo "Missing required release payload path: ${path}" >&2
    exit 1
  fi
}

require_path "${SCRIPT_DIR}/bin/tcube-pi"
require_path "${SCRIPT_DIR}/bin/tcube-pi-admin"
require_path "${SCRIPT_DIR}/bin/tcube-pi-admin-measure"
require_path "${SCRIPT_DIR}/admin-ui/index.html"
require_path "${SCRIPT_DIR}/content/content.json"
require_path "${SCRIPT_DIR}/deploy/pi-admin-caddy/Caddyfile"
require_path "${SCRIPT_DIR}/deploy/pi-admin-caddy/tcube-pi-admin.env"
require_path "${SCRIPT_DIR}/deploy/pi-admin-caddy/tcube-pi-admin.service"
require_path "${SCRIPT_DIR}/deploy/pi-admin-caddy/tcube-mdns-alias"
require_path "${SCRIPT_DIR}/deploy/pi-admin-caddy/tcube-mdns-alias.service"
require_path "${SCRIPT_DIR}/deploy/pi-runtime/tcube-pi.env"
require_path "${SCRIPT_DIR}/deploy/pi-runtime/tcube-pi.service"

detect_lan_address() {
  local candidate=""
  if command -v hostname >/dev/null 2>&1; then
    candidate="$(hostname -I 2>/dev/null | tr ' ' '\n' | awk '/^[0-9]+\./ && $1 !~ /^127\./ && $1 !~ /^169\.254\./ { print; exit }' || true)"
    if [[ -n "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return
    fi
  fi
  if command -v ip >/dev/null 2>&1; then
    ip -4 route get 1.1.1.1 2>/dev/null | awk '{ for (i = 1; i <= NF; i++) if ($i == "src") { print $(i + 1); exit } }'
  fi
}

add_caddy_site_address() {
  local site_address="$1"
  if [[ -z "${site_address}" ]]; then
    return 0
  fi
  local tmp_caddy
  tmp_caddy="$(mktemp)"
  awk -v site_address="${site_address}" '
    !updated && $0 ~ /^tcube\.local,/ && index($0, site_address) == 0 {
      sub(/ \{/, ", " site_address " {")
      updated = 1
    }
    { print }
  ' /etc/caddy/Caddyfile > "${tmp_caddy}"
  install -m 0644 "${tmp_caddy}" /etc/caddy/Caddyfile
  rm -f "${tmp_caddy}"
}

export_caddy_root_ca() {
  local ca_source=""
  local default_source="/var/lib/caddy/.local/share/caddy/pki/authorities/local/root.crt"
  for _ in $(seq 1 15); do
    if [[ -f "${default_source}" ]]; then
      ca_source="${default_source}"
      break
    fi
    ca_source="$(find /var/lib/caddy -type f -path '*/pki/authorities/local/root.crt' 2>/dev/null | head -n 1 || true)"
    if [[ -n "${ca_source}" ]]; then
      break
    fi
    sleep 1
  done
  if [[ -z "${ca_source}" ]]; then
    return 1
  fi
  install -d -o root -g root -m 0755 /opt/tcube/ca
  install -m 0644 "${ca_source}" /opt/tcube/ca/root.crt
}

file_digest() {
  if [[ -f "$1" ]]; then
    sha256sum "$1" | awk '{ print $1 }'
  fi
}

admin_service_state() {
  printf '%s|%s|%s\n' \
    "$(file_digest /opt/tcube/bin/tcube-pi-admin)" \
    "$(file_digest /etc/systemd/system/tcube-pi-admin.service)" \
    "$(file_digest /etc/tcube/tcube-pi-admin.env)"
}

mdns_service_state() {
  printf '%s|%s\n' \
    "$(file_digest /opt/tcube/bin/tcube-mdns-alias)" \
    "$(file_digest /etc/systemd/system/tcube-mdns-alias.service)"
}

runtime_service_state() {
  printf '%s|%s|%s|%s\n' \
    "$(file_digest /opt/tcube/bin/tcube-pi)" \
    "$(file_digest /etc/systemd/system/tcube-pi.service)" \
    "$(file_digest /etc/tcube/tcube-pi.env)" \
    "$(file_digest /opt/tcube/content/content.json)"
}

ensure_i2s_boot_config() {
  local boot_config="/boot/firmware/config.txt"
  if [[ ! -f "${boot_config}" ]] && [[ -f /boot/config.txt ]]; then
    boot_config="/boot/config.txt"
  fi
  if [[ ! -f "${boot_config}" ]]; then
    echo "WARNING: no boot config.txt found; enable the MAX98357A I2S overlay manually." >&2
    return 1
  fi
  # Detect any existing overlay line, not just the T-Cube marker comment, so
  # a Pi configured manually or by the smoke payload is never double-appended.
  if grep -Eq '^[[:space:]]*dtoverlay=max98357a' "${boot_config}"; then
    return 1
  fi
  cat >> "${boot_config}" <<'CONFIG'

# T-Cube MAX98357A I2S audio
dtparam=i2s=on
dtoverlay=max98357a
CONFIG
  return 0
}

release_version="${TCUBE_PI_VERSION:-}"
if [[ -z "${release_version}" ]]; then
  payload_dir_name="$(basename "${SCRIPT_DIR}")"
  if [[ "${payload_dir_name}" =~ ^tcube-pi-(v[0-9]+\.[0-9]+\.[0-9]+([-+][0-9A-Za-z.-]+)?)-linux-arm64$ ]]; then
    release_version="${BASH_REMATCH[1]}"
  fi
fi

echo "Installing T-Cube Pi release from ${SCRIPT_DIR}"

admin_state_before="$(admin_service_state)"
mdns_state_before="$(mdns_service_state)"
runtime_state_before="$(runtime_service_state)"

if ! id -u tcube >/dev/null 2>&1; then
  useradd --system --home /var/lib/tcube --shell /usr/sbin/nologin tcube
fi

install -d -o tcube -g tcube -m 0750 /var/lib/tcube /var/lib/tcube/media
install -d -o root -g root -m 0755 /opt/tcube/bin /opt/tcube/admin-ui /opt/tcube/content /etc/tcube

install -m 0755 "${SCRIPT_DIR}/bin/tcube-pi" /opt/tcube/bin/tcube-pi
install -m 0755 "${SCRIPT_DIR}/bin/tcube-pi-admin" /opt/tcube/bin/tcube-pi-admin
install -m 0755 "${SCRIPT_DIR}/bin/tcube-pi-admin-measure" /opt/tcube/bin/tcube-pi-admin-measure
install -m 0755 "${SCRIPT_DIR}/deploy/pi-admin-caddy/tcube-mdns-alias" /opt/tcube/bin/tcube-mdns-alias

rm -rf /opt/tcube/admin-ui/.new
install -d -o root -g root -m 0755 /opt/tcube/admin-ui/.new
cp -R "${SCRIPT_DIR}/admin-ui/." /opt/tcube/admin-ui/.new/
rm -rf /opt/tcube/admin-ui/assets /opt/tcube/admin-ui/index.html
cp -R /opt/tcube/admin-ui/.new/. /opt/tcube/admin-ui/
rm -rf /opt/tcube/admin-ui/.new

rm -rf /opt/tcube/content/.new
install -d -o root -g root -m 0755 /opt/tcube/content/.new
cp -R "${SCRIPT_DIR}/content/." /opt/tcube/content/.new/
rm -rf /opt/tcube/content/audio /opt/tcube/content/content.json
cp -R /opt/tcube/content/.new/. /opt/tcube/content/
rm -rf /opt/tcube/content/.new

env_note=""
if [[ -f /etc/tcube/tcube-pi-admin.env ]]; then
  install -D -m 0644 "${SCRIPT_DIR}/deploy/pi-admin-caddy/tcube-pi-admin.env" /etc/tcube/tcube-pi-admin.env.dist
  env_note="Kept existing /etc/tcube/tcube-pi-admin.env; new release defaults written to /etc/tcube/tcube-pi-admin.env.dist"
else
  install -D -m 0644 "${SCRIPT_DIR}/deploy/pi-admin-caddy/tcube-pi-admin.env" /etc/tcube/tcube-pi-admin.env
fi
runtime_env_note=""
if [[ -f /etc/tcube/tcube-pi.env ]]; then
  install -D -m 0644 "${SCRIPT_DIR}/deploy/pi-runtime/tcube-pi.env" /etc/tcube/tcube-pi.env.dist
  runtime_env_note="Kept existing /etc/tcube/tcube-pi.env; new release defaults written to /etc/tcube/tcube-pi.env.dist"
else
  install -D -m 0644 "${SCRIPT_DIR}/deploy/pi-runtime/tcube-pi.env" /etc/tcube/tcube-pi.env
fi
install -D -m 0644 "${SCRIPT_DIR}/deploy/pi-admin-caddy/tcube-pi-admin.service" /etc/systemd/system/tcube-pi-admin.service
install -D -m 0644 "${SCRIPT_DIR}/deploy/pi-admin-caddy/tcube-mdns-alias.service" /etc/systemd/system/tcube-mdns-alias.service
install -D -m 0644 "${SCRIPT_DIR}/deploy/pi-runtime/tcube-pi.service" /etc/systemd/system/tcube-pi.service
install -D -m 0644 "${SCRIPT_DIR}/deploy/pi-admin-caddy/Caddyfile" /etc/caddy/Caddyfile

reboot_needed=0
if ensure_i2s_boot_config; then
  reboot_needed=1
fi

if systemctl is-enabled --quiet tcube-button-smoke.service 2>/dev/null \
  || systemctl is-active --quiet tcube-button-smoke.service 2>/dev/null; then
  echo "Disabling the temporary tcube-button-smoke.service; tcube-pi.service supersedes it."
  systemctl disable --now tcube-button-smoke.service || true
fi

device_hostname="$(hostname 2>/dev/null || true)"
device_hostname="${device_hostname%%.*}"

installed_lan_address="$(detect_lan_address || true)"
add_caddy_site_address "${installed_lan_address}"
if [[ -n "${device_hostname}" && "${device_hostname}" != "tcube" ]]; then
  add_caddy_site_address "${device_hostname}.local"
fi

admin_state_after="$(admin_service_state)"
mdns_state_after="$(mdns_service_state)"
runtime_state_after="$(runtime_service_state)"

systemctl daemon-reload
systemctl enable tcube-pi-admin.service
if ! systemctl is-active --quiet tcube-pi-admin.service; then
  systemctl start tcube-pi-admin.service
elif [[ "${admin_state_before}" != "${admin_state_after}" ]]; then
  echo "Restarting tcube-pi-admin.service to apply the updated release..."
  systemctl restart tcube-pi-admin.service
fi
systemctl enable tcube-pi.service
if [[ "${reboot_needed}" -eq 1 ]]; then
  echo "The MAX98357A I2S overlay was added to the boot config; tcube-pi.service starts after the reboot."
elif ! systemctl is-active --quiet tcube-pi.service; then
  systemctl start tcube-pi.service
elif [[ "${runtime_state_before}" != "${runtime_state_after}" ]]; then
  echo "Restarting tcube-pi.service to apply the updated release..."
  systemctl restart tcube-pi.service
fi
if systemctl is-active --quiet caddy; then
  systemctl reload caddy
else
  systemctl enable --now caddy
fi

if [[ -n "${release_version}" ]]; then
  printf '%s\n' "${release_version}" > /opt/tcube/VERSION
  chmod 0644 /opt/tcube/VERSION
fi

mdns_notes=()
if ! systemctl is-active --quiet avahi-daemon; then
  mdns_notes+=("avahi-daemon is not active, so .local names will not resolve. Fix: sudo apt install -y avahi-daemon")
fi

if [[ "${device_hostname}" == "tcube" ]]; then
  mdns_notes+=("Hostname is tcube, so avahi announces tcube.local directly.")
  if systemctl is-enabled --quiet tcube-mdns-alias.service 2>/dev/null; then
    systemctl disable --now tcube-mdns-alias.service
  fi
elif command -v avahi-publish >/dev/null 2>&1; then
  if systemctl is-active --quiet tcube-mdns-alias.service && [[ "${mdns_state_before}" != "${mdns_state_after}" ]]; then
    systemctl restart tcube-mdns-alias.service
  fi
  if systemctl enable --now tcube-mdns-alias.service; then
    mdns_notes+=("Hostname is ${device_hostname}; tcube-mdns-alias.service publishes tcube.local for this cube.")
  else
    mdns_notes+=("tcube-mdns-alias.service failed to start; check: systemctl status tcube-mdns-alias --no-pager")
  fi
else
  mdns_notes+=("Hostname is ${device_hostname} and avahi-publish is missing, so https://tcube.local/ will NOT resolve yet.")
  mdns_notes+=("Fix: sudo apt install -y avahi-utils && sudo systemctl enable --now tcube-mdns-alias.service")
  if [[ -n "${device_hostname}" ]]; then
    mdns_notes+=("Until then, use https://${device_hostname}.local/ or the LAN IP URL below.")
  fi
fi

if command -v avahi-resolve-host-name >/dev/null 2>&1; then
  sleep 2
  resolved_tcube="$(avahi-resolve-host-name -4 tcube.local 2>/dev/null | awk '{ print $2 }' || true)"
  if [[ -n "${resolved_tcube}" ]]; then
    mdns_notes+=("Verified: tcube.local currently resolves to ${resolved_tcube}.")
  else
    mdns_notes+=("tcube.local did not resolve via mDNS yet; allow a few seconds after service start and re-check with: avahi-resolve-host-name -4 tcube.local")
  fi
fi

if export_caddy_root_ca; then
  ca_exported=1
else
  ca_exported=0
fi

ca_host="${installed_lan_address:-tcube.local}"

cat <<MESSAGE
T-Cube Pi release installed${release_version:+ (${release_version})}.
MESSAGE
if [[ -n "${env_note}" ]]; then
  echo "  ${env_note}"
fi
if [[ -n "${runtime_env_note}" ]]; then
  echo "  ${runtime_env_note}"
fi
if [[ "${reboot_needed}" -eq 1 ]]; then
  echo "  REBOOT REQUIRED: the I2S audio overlay only loads at boot. Run: sudo reboot"
fi
cat <<MESSAGE

Service checks (on the Pi):
  systemctl status tcube-pi --no-pager
  journalctl -u tcube-pi -f
  systemctl status tcube-pi-admin --no-pager
  systemctl status caddy --no-pager
  curl http://127.0.0.1:8080/api/pi/v1/status
  curl -k https://localhost/api/pi/v1/status

Button check: press the button on BCM GPIO17 (button 1) and listen for audio.
Edit /etc/tcube/tcube-pi.env if your buttons use different GPIO lines.

Admin URLs:
  https://tcube.local/
MESSAGE
if [[ -n "${device_hostname}" && "${device_hostname}" != "tcube" ]]; then
  echo "  https://${device_hostname}.local/"
fi
if [[ -n "${installed_lan_address}" ]]; then
  echo "  https://${installed_lan_address}/  (current LAN IP; can change with DHCP)"
fi

echo ""
echo "mDNS status:"
for note in "${mdns_notes[@]}"; do
  echo "  ${note}"
done

echo ""
if [[ "${ca_exported}" -eq 1 ]]; then
  echo "Certificate trust (one time per admin phone or laptop):"
  echo "  The cube serves its root certificate at http://${ca_host}/ca/root.crt"
  echo "  (also stored on the Pi at /opt/tcube/ca/root.crt)."
  echo ""
  echo "  macOS:"
  echo "    curl -fsSL http://${ca_host}/ca/root.crt -o ~/Downloads/tcube-root-ca.crt"
  echo "    sudo security add-trusted-cert -d -r trustRoot -k /Library/Keychains/System.keychain ~/Downloads/tcube-root-ca.crt"
  echo ""
  echo "  Linux:"
  echo "    sudo curl -fsSL http://${ca_host}/ca/root.crt -o /usr/local/share/ca-certificates/tcube-root-ca.crt"
  echo "    sudo update-ca-certificates"
  echo ""
  echo "  iPhone/iPad:"
  echo "    Open http://${ca_host}/ca/root.crt in Safari and allow the download."
  echo "    Install it under Settings > General > VPN & Device Management."
  echo "    Enable full trust under Settings > General > About > Certificate Trust Settings."
  echo ""
  echo "  Android:"
  echo "    Download http://${ca_host}/ca/root.crt, then install it under"
  echo "    Settings > Security > Encryption & credentials > Install a certificate > CA certificate."
else
  echo "WARNING: Caddy's internal root CA was not found under /var/lib/caddy, so it was not"
  echo "exported to /opt/tcube/ca/root.crt and http://${ca_host}/ca/root.crt will 404."
  echo "After Caddy has fully started, re-run this installer or copy it manually:"
  echo "  sudo install -d -m 0755 /opt/tcube/ca"
  echo "  sudo install -m 0644 /var/lib/caddy/.local/share/caddy/pki/authorities/local/root.crt /opt/tcube/ca/root.crt"
fi

echo ""
echo "From an admin device after trusting the certificate:"
echo "  curl https://tcube.local/api/pi/v1/status"
if [[ -n "${installed_lan_address}" ]]; then
  echo "  curl https://${installed_lan_address}/api/pi/v1/status"
fi
