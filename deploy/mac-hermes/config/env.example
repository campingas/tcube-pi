# Copy the values you need into ~/.hermes/.env on the Mac Mini.
# Hermes injects declared skill environment variables into terminal and execute_code sandboxes.

# Pi ingest API (through the Pi's Caddy HTTPS front).
TCUBE_PI_BASE_URL=https://tcube.local
# Must match TCUBE_ORCH_TOKEN in deploy/pi-admin-caddy/tcube-pi-admin.env on the Pi. 32 bytes minimum.
# Generate with: openssl rand -hex 32
TCUBE_ORCH_TOKEN=change-me-generate-a-random-64-hex-token
# Pi Caddy internal root CA, exported from the Pi (see deploy/mac-hermes/README.md).
TCUBE_PI_CA_CERT=~/.hermes/tcube-pi-ca.pem

# Shared HMAC secret for the tcube-jobs webhook route. Must match HERMES_WEBHOOK_SECRET on the Pi.
# Generate with: openssl rand -hex 32
TCUBE_WEBHOOK_SECRET=change-me-generate-a-random-64-hex-secret

# Local Voxtral TTS server (OpenAI-compatible /v1/audio/speech).
VOXTRAL_API_BASE=https://127.0.0.1:11445
# Optional CA bundle if the Voxtral endpoint uses a private CA (Caddy tls internal).
#VOXTRAL_API_CA_CERT=
# Optional model override for generate_batch.py.
#VOXTRAL_TTS_MODEL=mistralai/Voxtral-4B-TTS-2603
