tcube.local, 10.55.0.1, localhost, 127.0.0.1 {
	bind 0.0.0.0
	tls internal
	encode zstd gzip

	handle /ca/root.crt {
		root * /opt/tcube
		header Content-Type application/x-x509-ca-cert
		file_server
	}

	handle {
		# Content-hashed build assets are immutable; let browsers cache them
		# for a year so repeat loads skip the network and the Pi skips re-serving.
		header /assets/* Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy 127.0.0.1:8080
	}
}

http:// {
	bind 0.0.0.0

	handle /ca/root.crt {
		root * /opt/tcube
		header Content-Type application/x-x509-ca-cert
		file_server
	}

	handle {
		redir https://{host}{uri}
	}
}
