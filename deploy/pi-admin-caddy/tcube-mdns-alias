#!/usr/bin/env bash
set -euo pipefail

# Publishes an extra mDNS host record so admin devices can reach the cube at
# https://tcube.local/ even when the Pi hostname is not "tcube".
# avahi-daemon only announces "<hostname>.local" on its own.

alias_name="${TCUBE_MDNS_ALIAS:-tcube.local}"

detect_lan_address() {
  local candidate=""
  if command -v hostname >/dev/null 2>&1; then
    candidate="$(hostname -I 2>/dev/null | tr ' ' '\n' | awk '/^[0-9]+\./ && $1 !~ /^127\./ && $1 !~ /^169\.254\./ { print; exit }' || true)"
    if [[ -n "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return
    fi
  fi
  if command -v ip >/dev/null 2>&1; then
    ip -4 route get 1.1.1.1 2>/dev/null | awk '{ for (i = 1; i <= NF; i++) if ($i == "src") { print $(i + 1); exit } }'
  fi
}

if ! command -v avahi-publish >/dev/null 2>&1; then
  echo "avahi-publish is not installed; install avahi-utils to publish ${alias_name}" >&2
  exit 1
fi

address="$(detect_lan_address || true)"
if [[ -z "${address}" ]]; then
  echo "No LAN address detected; cannot publish ${alias_name}" >&2
  exit 1
fi

exec avahi-publish -a -R "${alias_name}" "${address}"
