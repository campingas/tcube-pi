TCUBE_PI_ADMIN_BIND=127.0.0.1:8080
TCUBE_PI_ADMIN_DATABASE=/var/lib/tcube/tcube.sqlite3
TCUBE_PI_ADMIN_UI_DIST=/opt/tcube/admin-ui
TCUBE_PI_ADMIN_MEDIA_ROOT=/var/lib/tcube/media
TCUBE_PI_ADMIN_CONTENT_ROOT=/opt/tcube/content
TCUBE_PI_ADMIN_HOSTNAME=tcube.local
TCUBE_PI_ADMIN_USB_ADDRESS=10.55.0.1
VOXTRAL_API_BASE=https://127.0.0.1:11445
VIETNAMESE_VITS_API_BASE=https://127.0.0.1:11446
# If the TTS services use Caddy tls internal and the Caddy root CA is not
# trusted system-wide by this service account, point this at the exported root
# certificate PEM so Rust/reqwest can validate the local HTTPS service.
# TCUBE_SPEECH_API_CA_CERT=/etc/tcube/caddy-root-ca.pem
