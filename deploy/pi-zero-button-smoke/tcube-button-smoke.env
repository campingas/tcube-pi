# BCM GPIO number, not physical pin number.
# Full five-button schematic Button 1: BCM GPIO5, physical pin 29.
# Older breadboard smoke diagram label: BCM GPIO4.
BUTTON_GPIO=5
GPIO_CHIP=gpiochip0

# Choose one folder for the one-button smoke test.
AUDIO_DIR=/opt/tcube/content/audio/english
# AUDIO_DIR=/opt/tcube/content/audio/animals
# AUDIO_DIR=/opt/tcube/content/audio/music

DEBOUNCE_MS=250
VOLUME_PERCENT=80

