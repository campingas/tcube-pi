# BCM GPIO number, not physical pin number.
# Five-button assembly button 1 (red) and breadboard starter: BCM GPIO17, physical pin 11.
# Five-button assembly button 4 (blue): BCM GPIO5, physical pin 29.
# Older breadboard smoke diagram label: BCM GPIO4.
BUTTON_GPIO=17
GPIO_CHIP=gpiochip0

# Choose one folder for the one-button smoke test.
AUDIO_DIR=/opt/tcube/content/audio/english
# AUDIO_DIR=/opt/tcube/content/audio/animals
# AUDIO_DIR=/opt/tcube/content/audio/music

# Explicitly target the MAX98357A I2S card instead of the HDMI default.
ALSA_DEVICE=plughw:CARD=MAX98357A,DEV=0

DEBOUNCE_MS=250
VOLUME_PERCENT=80
