TCUBE_PI_CONTENT=/opt/tcube/content/content.json
TCUBE_PI_DATABASE=/var/lib/tcube/tcube.sqlite3
TCUBE_PI_AUDIO=local
TCUBE_PI_AUDIO_ROOT=/opt/tcube
TCUBE_PI_MEDIA_ROOT=/var/lib/tcube/media
# Comma-separated BCM GPIO lines for buttons 1 through 5, in button order.
# Default matches docs/hardware/hardware-assembly.md: red=17, green=27,
# yellow=22, blue=5, white=6. The one-button breadboard starter uses GPIO17
# and works unchanged as button 1. A partial list (for example just 17)
# claims only that many buttons.
TCUBE_PI_BUTTON_GPIOS=17,27,22,5,6
# Pin the ALSA default card to the MAX98357A I2S amplifier; card 0 is the HDMI
# output on Raspberry Pi OS and stock alsa-lib resolves the default card from
# this variable. If a future alsa.conf stops honouring ALSA_CARD, create
# /etc/asound.conf with: defaults.pcm.card MAX98357A / defaults.ctl.card MAX98357A
ALSA_CARD=MAX98357A
